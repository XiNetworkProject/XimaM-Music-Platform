{
  "expo": {
    "name": "Synaura",
    "slug": "synaura",
    "scheme": "synaura",
    "version": "0.21.0",
    "icon": "./src/assets/synaura-symbol-2026.png",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.synaura.music",
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "package": "com.synaura.music",
      "googleServicesFile": "./google-services.json",
      "versionCode": 65,
      "newArchEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/synaura-symbol-2026.png",
        "backgroundColor": "#050505"
      },
      "permissions": [
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.REQUEST_INSTALL_PACKAGES",
        "android.permission.WAKE_LOCK"
      ]
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D0D0D",
          "image": "./src/assets/synaura-symbol-2026.png",
          "imageWidth": 170,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./src/assets/synaura-symbol-2026.png",
          "color": "#7357C6",
          "defaultChannel": "synaura-activity"
        }
      ],
      "expo-secure-store",
      "./plugins/with-synaura-theme-colors"
    ],
    "androidStatusBar": {
      "backgroundColor": "#0D0D0D",
      "barStyle": "light-content",
      "translucent": false
    },
    "androidNavigationBar": {
      "backgroundColor": "#0D0D0D",
      "barStyle": "light-content"
    },
    "extra": {
      "apiBaseUrl": "https://xima-m-music-platform.vercel.app",
      "mobileReleaseManifestUrl": "https://ekddunxvtatdvxbszcsh.supabase.co/storage/v1/object/public/mobile-releases/latest.json",
      "eas": {
        "projectId": "9159837f-1150-456d-885a-1751a7f616ea"
      }
    },
    "owner": "ximamoff"
  }
}
