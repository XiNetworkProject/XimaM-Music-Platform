{
  "expo": {
    "name": "Synaura",
    "slug": "synaura",
    "scheme": "synaura",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "bundleIdentifier": "com.synaura.music",
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "package": "com.synaura.music",
      "adaptiveIcon": {
        "backgroundColor": "#050214"
      },
      "permissions": [
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.WAKE_LOCK"
      ]
    },
    "plugins": [
      "expo-splash-screen"
    ],
    "extra": {
      "apiBaseUrl": "https://xima-m-music-platform.vercel.app"
    }
  }
}
